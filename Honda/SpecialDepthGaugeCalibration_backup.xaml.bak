<Window x:Class="SpecialDepthGaugeCalibration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="Special Depth Gauge Calibration" Height="765" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Segoe UI Variable, Arial">

    <!-- Global Styles for modern look -->
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                 BorderBrush="{TemplateBinding BorderBrush}" 
                                 BorderThickness="{TemplateBinding BorderThickness}" 
                                 CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Margin="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Row 0: Heading -->
                <RowDefinition Height="Auto" /> <!-- Row 1: Header Section -->
                <RowDefinition Height="Auto" /> <!-- Row 2: Environmental Conditions -->
                <RowDefinition Height="Auto" /> <!-- Row 3: Selected Calibration Masters -->
                <RowDefinition Height="Auto" /> <!-- Row 4: Observations -->
                <RowDefinition Height="Auto" /> <!-- Row 5: Bottom Section -->
                <RowDefinition Height="Auto" /> <!-- Row 6: Save/Submit Button -->
            </Grid.RowDefinitions>

            <!-- Top Left Heading -->
            <TextBlock Grid.Row="0" Text="Special Depth Gauge Calibration" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10" HorizontalAlignment="Left" />

            <!-- Header and Base Details GroupBox -->
            <GroupBox Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Control No :" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtControlNo" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Category/Control :" />
                    <ComboBox Grid.Row="0" Grid.Column="4" x:Name="ComboCategory" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Calibration Date :" />
                    <DatePicker Grid.Row="0" Grid.Column="7" x:Name="TxtCalibrationDate" HorizontalAlignment="Stretch" Height="34" VerticalContentAlignment="Center" />

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Colour :" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboColour" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Location :" />
                    <ComboBox Grid.Row="2" Grid.Column="4" x:Name="ComboLocation" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="6" Text="LC :" />
                    <ComboBox Grid.Row="2" Grid.Column="7" x:Name="ComboLC" HorizontalAlignment="Stretch" />

                    <!-- Row 4 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Calibration master:" />
                    <Grid Grid.Row="4" Grid.Column="1">
                        <Button x:Name="BtnBrowseMaster" Content="..." Width="60" Height="26" HorizontalAlignment="Left" Click="BtnBrowseMaster_Click" />
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Environmental Conditions GroupBox -->
            <GroupBox Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Temp :" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTemp" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Humidity :" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtHumidity" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="TMU :" />
                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="TxtTMU" IsReadOnly="True" Background="#F1F5F9" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="MU :" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMU" HorizontalAlignment="Stretch" ToolTip="Enter Master Uncertainty (MU) manually. TMU will be recalculated automatically." />
                </Grid>
            </GroupBox>

            <!-- Selected Calibration Masters (Dynamic Section) -->
            <GroupBox x:Name="MasterGroupBox" Grid.Row="3" Visibility="Collapsed" Margin="0,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsControlSelectedMasters">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="12,6" Margin="0,0,10,6" Background="#F8FAFC">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" />
                                        <TextBlock Text=" | " Foreground="#64748B" Margin="6,0" />
                                        <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- Observations GroupBox -->
            <GroupBox Grid.Row="4">
                <GroupBox.Header>
                    <TextBlock Text="Parameter Entries &amp; Observations" FontWeight="Bold" Foreground="#1E293B" FontSize="14" />
                </GroupBox.Header>
                <StackPanel>
                    <!-- Dia 1 Row -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" /> <!-- Label -->
                            <ColumnDefinition Width="55" /> <!-- Nominal -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl PermErr -->
                            <ColumnDefinition Width="65" /> <!-- PermErr -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Min -->
                            <ColumnDefinition Width="65" /> <!-- Min -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Max -->
                            <ColumnDefinition Width="65" /> <!-- Max -->
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" /> <!-- 1: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 2: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 3: -->
                            <ColumnDefinition Width="65" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Dia 1 :" FontWeight="SemiBold" />
                        <TextBox Grid.Column="1" x:Name="TxtDia1Nominal" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="3" Text="± PermErr:" FontSize="12" />
                        <TextBox Grid.Column="4" x:Name="TxtDia1PermErr" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="6" Text="Min:" FontSize="12" />
                        <TextBox Grid.Column="7" x:Name="TxtDia1Min" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="9" Text="Max:" FontSize="12" />
                        <TextBox Grid.Column="10" x:Name="TxtDia1Max" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="12" Text="1:" />
                        <TextBox Grid.Column="13" x:Name="TxtDia1Obs1" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="15" Text="2:" />
                        <TextBox Grid.Column="16" x:Name="TxtDia1Obs2" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="18" Text="3:" />
                        <TextBox Grid.Column="19" x:Name="TxtDia1Obs3" TextChanged="TrialTextChanged" />
                    </Grid>
                    
                    <!-- Dia 2 Row -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" /> <!-- Label -->
                            <ColumnDefinition Width="55" /> <!-- Nominal -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl PermErr -->
                            <ColumnDefinition Width="65" /> <!-- PermErr -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Min -->
                            <ColumnDefinition Width="65" /> <!-- Min -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Max -->
                            <ColumnDefinition Width="65" /> <!-- Max -->
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" /> <!-- 1: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 2: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 3: -->
                            <ColumnDefinition Width="65" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Dia 2 :" FontWeight="SemiBold" />
                        <TextBox Grid.Column="1" x:Name="TxtDia2Nominal" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="3" Text="± PermErr:" FontSize="12" />
                        <TextBox Grid.Column="4" x:Name="TxtDia2PermErr" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="6" Text="Min:" FontSize="12" />
                        <TextBox Grid.Column="7" x:Name="TxtDia2Min" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="9" Text="Max:" FontSize="12" />
                        <TextBox Grid.Column="10" x:Name="TxtDia2Max" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="12" Text="1:" />
                        <TextBox Grid.Column="13" x:Name="TxtDia2Obs1" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="15" Text="2:" />
                        <TextBox Grid.Column="16" x:Name="TxtDia2Obs2" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="18" Text="3:" />
                        <TextBox Grid.Column="19" x:Name="TxtDia2Obs3" TextChanged="TrialTextChanged" />
                    </Grid>
                    
                    <!-- Distance Row -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" /> <!-- Label -->
                            <ColumnDefinition Width="55" /> <!-- Nominal -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl PermErr -->
                            <ColumnDefinition Width="65" /> <!-- PermErr -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Min -->
                            <ColumnDefinition Width="65" /> <!-- Min -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Max -->
                            <ColumnDefinition Width="65" /> <!-- Max -->
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" /> <!-- 1: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 2: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 3: -->
                            <ColumnDefinition Width="65" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Distance :" FontWeight="SemiBold" />
                        <TextBox Grid.Column="1" x:Name="TxtDistNominal" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="3" Text="± PermErr:" FontSize="12" />
                        <TextBox Grid.Column="4" x:Name="TxtDistPermErr" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="6" Text="Min:" FontSize="12" />
                        <TextBox Grid.Column="7" x:Name="TxtDistMin" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="9" Text="Max:" FontSize="12" />
                        <TextBox Grid.Column="10" x:Name="TxtDistMax" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="12" Text="1:" />
                        <TextBox Grid.Column="13" x:Name="TxtDistObs1" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="15" Text="2:" />
                        <TextBox Grid.Column="16" x:Name="TxtDistObs2" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="18" Text="3:" />
                        <TextBox Grid.Column="19" x:Name="TxtDistObs3" TextChanged="TrialTextChanged" />
                    </Grid>
                    
                    <!-- Angle 1 Row -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" /> <!-- Label -->
                            <ColumnDefinition Width="55" /> <!-- Nominal -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl PermErr -->
                            <ColumnDefinition Width="65" /> <!-- PermErr -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Min -->
                            <ColumnDefinition Width="65" /> <!-- Min -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Max -->
                            <ColumnDefinition Width="65" /> <!-- Max -->
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" /> <!-- 1: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 2: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 3: -->
                            <ColumnDefinition Width="65" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Angle 1 :" FontWeight="SemiBold" ToolTip="Unit: Sec" />
                        <TextBox Grid.Column="1" x:Name="TxtAng1Nominal" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="3" Text="± PermErr:" FontSize="12" />
                        <TextBox Grid.Column="4" x:Name="TxtAng1PermErr" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="6" Text="Min:" FontSize="12" />
                        <TextBox Grid.Column="7" x:Name="TxtAng1Min" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="9" Text="Max:" FontSize="12" />
                        <TextBox Grid.Column="10" x:Name="TxtAng1Max" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="12" Text="1:" />
                        <TextBox Grid.Column="13" x:Name="TxtAng1Obs1" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="15" Text="2:" />
                        <TextBox Grid.Column="16" x:Name="TxtAng1Obs2" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="18" Text="3:" />
                        <TextBox Grid.Column="19" x:Name="TxtAng1Obs3" TextChanged="TrialTextChanged" />
                    </Grid>
                    
                    <!-- Angle 2 Row -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" /> <!-- Label -->
                            <ColumnDefinition Width="55" /> <!-- Nominal -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl PermErr -->
                            <ColumnDefinition Width="65" /> <!-- PermErr -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Min -->
                            <ColumnDefinition Width="65" /> <!-- Min -->
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="Auto" /> <!-- Lbl Max -->
                            <ColumnDefinition Width="65" /> <!-- Max -->
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" /> <!-- 1: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 2: -->
                            <ColumnDefinition Width="65" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" /> <!-- 3: -->
                            <ColumnDefinition Width="65" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Angle 2 :" FontWeight="SemiBold" ToolTip="Unit: Sec" />
                        <TextBox Grid.Column="1" x:Name="TxtAng2Nominal" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="3" Text="± PermErr:" FontSize="12" />
                        <TextBox Grid.Column="4" x:Name="TxtAng2PermErr" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="6" Text="Min:" FontSize="12" />
                        <TextBox Grid.Column="7" x:Name="TxtAng2Min" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="9" Text="Max:" FontSize="12" />
                        <TextBox Grid.Column="10" x:Name="TxtAng2Max" TextChanged="TxtParameter_TextChanged" />
                        
                        <TextBlock Grid.Column="12" Text="1:" />
                        <TextBox Grid.Column="13" x:Name="TxtAng2Obs1" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="15" Text="2:" />
                        <TextBox Grid.Column="16" x:Name="TxtAng2Obs2" TextChanged="TrialTextChanged" />
                        
                        <TextBlock Grid.Column="18" Text="3:" />
                        <TextBox Grid.Column="19" x:Name="TxtAng2Obs3" TextChanged="TrialTextChanged" />
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Bottom Section (Parameters, Judgement, etc) -->
            <GroupBox Grid.Row="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Parameters :" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtParameters" Text="Special Depth" IsReadOnly="True" Background="#F1F5F9" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Judgement :" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtJudgement" IsReadOnly="True" Background="#F1F5F9" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Time In :" />
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtTimeIn" TextChanged="Time_TextChanged" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Time Out :" />
                    <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtTimeOut" TextChanged="Time_TextChanged" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Total Time :" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtTotalTime" IsReadOnly="True" Background="#F1F5F9" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Remarks :" />
                    <TextBox Grid.Row="4" Grid.Column="4" x:Name="TxtRemarks" HorizontalAlignment="Stretch" />
                </Grid>
            </GroupBox>

            <!-- Save Button -->
            <Grid Grid.Row="6" Margin="0,10,0,20">
                <Button x:Name="BtnUpdate" Content="Save Calibration" Width="200" HorizontalAlignment="Right" Click="BtnUpdate_Click" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
