<Window x:Class="GrooveMicrometer50"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="Groove Micrometer 25-50 mm" Height="850" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Segoe UI Variable, Arial">

    <Window.Resources>
        <!-- Modern Style Definitions -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Margin="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Heading -->
                <RowDefinition Height="Auto" /> <!-- Header Info -->
                <RowDefinition Height="Auto" /> <!-- Environmental -->
                <RowDefinition Height="Auto" /> <!-- Selected Calibration Masters -->
                <RowDefinition Height="Auto" /> <!-- Observations -->
                <RowDefinition Height="Auto" /> <!-- Bottom tracking -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Groove Micrometer 25-50 mm" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12" />

            <!-- Header Section -->
            <GroupBox Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Control No:" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextBox1" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Category:" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ComboBox1" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Location:" />
                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="ComboBox2" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="LC (mm):" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboBox5" />

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Calibration Date:" />
                    <DatePicker Grid.Row="2" Grid.Column="4" x:Name="TxtCalibrationDate" VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2" Grid.Column="6" Text="Size:" />
                    <ComboBox Grid.Row="2" Grid.Column="7" x:Name="TextBox21" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Color:" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TextBoxColor" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Calibration master:" />
                    <Grid Grid.Row="4" Grid.Column="4">
                        <Button x:Name="BtnBrowseMaster" Content="..." Width="60" Height="26" HorizontalAlignment="Left" Click="BtnBrowseMaster_Click" />
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Environmental Conditions -->
            <GroupBox Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="75" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="45" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Temperature:" />
                    <TextBox Grid.Column="1" x:Name="TextBox30" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="3" Text="Humidity:" />
                    <TextBox Grid.Column="4" x:Name="TextBox28" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="6" Text="TMU:" />
                    <TextBox Grid.Column="7" x:Name="TextBox29" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Column="9" Text="Depth Error:" />
                    <TextBox Grid.Column="10" x:Name="TextBox20" HorizontalAlignment="Stretch" />
                </Grid>
            </GroupBox>

            <!-- Selected Calibration Masters -->
            <GroupBox x:Name="MasterGroupBox" Grid.Row="3" Visibility="Collapsed" Margin="0,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsControlSelectedMasters">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="12,6" Margin="0,0,10,6" Background="#F8FAFC">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" />
                                        <TextBlock Text=" | " Foreground="#64748B" Margin="6,0" />
                                        <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- Observations Section -->
            <GroupBox Grid.Row="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- External Observation -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="External Observation" FontWeight="Bold" FontSize="15" Foreground="#1E293B" Margin="0,0,0,16" HorizontalAlignment="Left" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Foreground" Value="#475569" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Height" Value="38" />
                                    <Setter Property="Width" Value="48" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="BorderBrush" Value="#CBD5E1" />
                                    <Setter Property="Background" Value="#F8FAFC" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6" />
                                                        <Setter TargetName="border" Property="BorderThickness" Value="1.5" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <!-- Column 1: 25, 30, 35 -->
                            <StackPanel Grid.Column="0">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="25 mm:" x:Name="LabelExt25" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtExt25_1" />
                                        <TextBox x:Name="txtExt25_2" />
                                        <TextBox x:Name="txtExt25_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="30 mm:" x:Name="LabelExt30" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtExt30_1" />
                                        <TextBox x:Name="txtExt30_2" />
                                        <TextBox x:Name="txtExt30_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="35 mm:" x:Name="LabelExt35" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtExt35_1" />
                                        <TextBox x:Name="txtExt35_2" />
                                        <TextBox x:Name="txtExt35_3" />
                                    </UniformGrid>
                                </Grid>
                            </StackPanel>

                            <!-- Column 2: 40, 45, 50 -->
                            <StackPanel Grid.Column="2">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="40 mm:" x:Name="LabelExt40" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtExt40_1" />
                                        <TextBox x:Name="txtExt40_2" />
                                        <TextBox x:Name="txtExt40_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="45 mm:" x:Name="LabelExt45" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtExt45_1" />
                                        <TextBox x:Name="txtExt45_2" />
                                        <TextBox x:Name="txtExt45_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="50 mm:" x:Name="LabelExt50" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtExt50_1" />
                                        <TextBox x:Name="txtExt50_2" />
                                        <TextBox x:Name="txtExt50_3" />
                                    </UniformGrid>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Internal Observation -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Internal Observation" FontWeight="Bold" FontSize="15" Foreground="#1E293B" Margin="0,0,0,16" HorizontalAlignment="Left" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Foreground" Value="#475569" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Height" Value="38" />
                                    <Setter Property="Width" Value="48" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="BorderBrush" Value="#CBD5E1" />
                                    <Setter Property="Background" Value="#F8FAFC" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6" />
                                                        <Setter TargetName="border" Property="BorderThickness" Value="1.5" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <!-- Column 1: 25, 30, 35 -->
                            <StackPanel Grid.Column="0">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="25 mm:" x:Name="LabelInt25" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtInt25_1" />
                                        <TextBox x:Name="txtInt25_2" />
                                        <TextBox x:Name="txtInt25_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="30 mm:" x:Name="LabelInt30" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtInt30_1" />
                                        <TextBox x:Name="txtInt30_2" />
                                        <TextBox x:Name="txtInt30_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="35 mm:" x:Name="LabelInt35" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtInt35_1" />
                                        <TextBox x:Name="txtInt35_2" />
                                        <TextBox x:Name="txtInt35_3" />
                                    </UniformGrid>
                                </Grid>
                            </StackPanel>

                            <!-- Column 2: 40, 45, 50 -->
                            <StackPanel Grid.Column="2">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="40 mm:" x:Name="LabelInt40" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtInt40_1" />
                                        <TextBox x:Name="txtInt40_2" />
                                        <TextBox x:Name="txtInt40_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="45 mm:" x:Name="LabelInt45" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtInt45_1" />
                                        <TextBox x:Name="txtInt45_2" />
                                        <TextBox x:Name="txtInt45_3" />
                                    </UniformGrid>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="50 mm:" x:Name="LabelInt50" />
                                    <UniformGrid Grid.Column="1" Columns="3">
                                        <TextBox x:Name="txtInt50_1" />
                                        <TextBox x:Name="txtInt50_2" />
                                        <TextBox x:Name="txtInt50_3" />
                                    </UniformGrid>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Bottom Section -->
            <GroupBox Grid.Row="5" Margin="0,6,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Time In:" />
                        <TextBox Grid.Column="1" x:Name="TextBox24" />

                        <TextBlock Grid.Column="3" Text="Time Out:" />
                        <TextBox Grid.Column="4" x:Name="TextBox26" />

                        <TextBlock Grid.Column="6" Text="Total Duration:" />
                        <TextBox Grid.Column="7" x:Name="TextBox25" IsReadOnly="True" Background="#F1F5F9" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Status:" />
                        <ComboBox Grid.Column="1" x:Name="ComboBox4" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="OK" />
                            <ComboBoxItem Content="NG" />
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Remarks:" />
                        <TextBox Grid.Column="4" x:Name="TextBox19" HorizontalAlignment="Stretch" />
                        
                        <TextBox x:Name="TextBox27" Visibility="Collapsed" />
                    </Grid>

                    <Button Grid.Row="4" x:Name="Button2" Content="SAVE FINAL RECORD" Height="42" FontSize="15" FontWeight="Bold" Width="260" HorizontalAlignment="Center" />
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
