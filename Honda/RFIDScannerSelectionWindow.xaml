<Window x:Class="RFIDScannerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="RFID Scanner Selection" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border CornerRadius="12" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="20,15" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📡" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="RFID Scanner Configuration" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1" Margin="20,15,20,5" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Padding" Value="15,8"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#3B82F6"/>
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <!-- USB Scanner Tab -->
                <TabItem Header="USB Scanner">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Border Padding="10,15">
                            <StackPanel>
                                <TextBlock Text="Select the RFID scanner hardware implementation to use:" 
                                           Foreground="#64748B" FontSize="14" Margin="0,0,20,0" TextWrapping="Wrap"/>
            
                                <StackPanel Margin="0,15,0,0">
                                    <RadioButton x:Name="RbThinkMagic" GroupName="ScannerType" Margin="0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel>
                                                <TextBlock Text="ThinkMagic RFID Scanner" FontWeight="Medium" Foreground="#1E293B"/>
                                                <TextBlock Text="Mercury API based implementation" FontSize="12" Foreground="#64748B"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </RadioButton>
            
                                    <RadioButton x:Name="RbRDL" GroupName="ScannerType" Margin="0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel>
                                                <TextBlock Text="RDL RFID Scanner" FontWeight="Medium" Foreground="#1E293B"/>
                                                <TextBlock Text="Direct Serial Port implementation" FontSize="12" Foreground="#64748B"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
            
                                <!-- COM Port Selection -->
                                <StackPanel Margin="0,20,0,0">
                                    <TextBlock Text="COM Port (USB Scanner):" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ComboPorts" Padding="10,8" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1">
                                            <ComboBox.Resources>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>
                                        <Button x:Name="BtnRefreshPorts" Grid.Column="1" Content="🔄" Click="BtnRefreshPorts_Click" 
                                                Margin="10,0,0,0" Padding="10,5" Background="#F1F5F9" BorderBrush="#CBD5E1" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="Likely RFID readers (USB/Micro) are automatically prioritized and pre-selected." 
                                               FontSize="11" Foreground="#64748B" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
            
                                <!-- EPC Prefix Filter -->
                                <StackPanel Margin="0,20,0,0">
                                    <TextBlock Text="Tag Filter Mode:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                        <RadioButton x:Name="RbFilterAll" Content="All Tags" GroupName="FilterMode" Margin="0,0,20,0" Checked="RbFilterMode_Changed"/>
                                        <RadioButton x:Name="RbFilterPrefix" Content="Prefix Based" GroupName="FilterMode" Checked="RbFilterMode_Changed"/>
                                    </StackPanel>
            
                                    <TextBox x:Name="TxtPrefix" Padding="10,8" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1" 
                                             Background="#F8FAFC" Foreground="#1E293B">
                                        <TextBox.Resources>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <TextBlock Text="Only tags starting with this value will be processed if Prefix Based is selected." 
                                               FontSize="11" Foreground="#64748B" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
            
                                <!-- Scan Power / Distance -->
                                <StackPanel Margin="0,20,0,0">
                                    <Grid Margin="0,0,0,5">
                                        <TextBlock Text="Scan Power / Distance:" FontWeight="SemiBold" Foreground="#1E293B" HorizontalAlignment="Left"/>
                                        <TextBlock x:Name="LblPowerValue" Text="20 dBm" FontWeight="SemiBold" Foreground="#3B82F6" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="SldPower" Minimum="5" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" 
                                            Value="20" Margin="0,5"/>
                                    <Grid>
                                        <TextBlock Text="Min (Short)" FontSize="10" Foreground="#64748B" HorizontalAlignment="Left"/>
                                        <TextBlock Text="Max (Long Range)" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <!-- RFID Gun Tab -->
                <TabItem Header="RFID Gun / Handheld">
                    <Border Padding="10,15">
                        <StackPanel>
                            <TextBlock Text="Configure the connection details for the wireless RFID scanning gun." 
                                       Foreground="#64748B" FontSize="14" Margin="0,0,20,20" TextWrapping="Wrap"/>
                            
                            <!-- IP Address -->
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="IP Address:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtGunIp" Padding="10,8" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1" 
                                         Background="#F8FAFC" Foreground="#1E293B">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="Example: 192.168.1.51" 
                                           FontSize="11" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Port -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Port:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtGunPort" Padding="10,8" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1" 
                                         Background="#F8FAFC" Foreground="#1E293B">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="Example: 3000" 
                                           FontSize="11" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Backend Executable Path -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="Backend Executable Path:" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBackendPath" Padding="10,8" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1" 
                                             Background="#F8FAFC" Foreground="#1E293B">
                                        <TextBox.Resources>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="CornerRadius" Value="6,0,0,6"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                    <Button x:Name="BtnBrowseBackend" Grid.Column="1" Content="Browse..." Click="BtnBrowseBackend_Click" 
                                            Padding="15,8" Background="#F1F5F9" BorderBrush="#CBD5E1" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                                <TextBlock Text="Example: C:\Users\Administrator\Downloads\rfid-backend.exe" 
                                           FontSize="11" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel>
                                <Separator Margin="0,0,0,15" Background="#E2E8F0" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button x:Name="BtnTestConnection" Content="Test Connection" Click="BtnTestConnection_Click" 
                                            Padding="20,10" Background="#F1F5F9" Foreground="#334155" FontSize="13" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#CBD5E1" Margin="0,0,10,0">
                                        <Button.Resources>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    
                                    <Button x:Name="BtnStartBackend" Content="Start Backend Manually" Click="BtnStartBackend_Click" 
                                            Padding="20,10" Background="#F1F5F9" Foreground="#334155" FontSize="13" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#CBD5E1">
                                        <Button.Resources>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="System IP Address: " Foreground="#64748B" FontSize="13"/>
                        <TextBlock x:Name="LblSystemIp" Text="Fetching..." Foreground="#1E293B" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancel" Content="Cancel" Click="BtnCancel_Click" 
                                Width="80" Height="35" Margin="0,0,10,0"
                                Background="Transparent" BorderBrush="#CBD5E1" Foreground="#475569">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="1" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <Button x:Name="BtnSave" Content="Save Changes" Click="BtnSave_Click"
                                Width="120" Height="35"
                                Background="#3B82F6" BorderThickness="0" Foreground="White" FontWeight="SemiBold">
                             <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
