<Page x:Class="InventoryManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Inventory Management"
      Background="#F1F5F9"
      UseLayoutRounding="True"
      TextOptions.TextFormattingMode="Display">

    <Page.Resources>
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="30,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6,6,0,0" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#0263E0" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- New Styles for Audit Tab -->
        <Style x:Key="GroupFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,8" />
            <Setter Property="Width" Value="110" />
            <Setter Property="Margin" Value="0,0,12,10" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#0263E0" />
                                <Setter TargetName="border" Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuditDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="ColumnHeaderHeight" Value="45" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="Selector.IsSelectionActive" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#0263E0" />
                    <Setter Property="Foreground" Value="White" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridCellTextBlockStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Foreground}" />
        </Style>

        <Style x:Key="TextLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#0263E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        Background="{TemplateBinding Background}" 
                                        Grid.Column="2" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                        Focusable="false"
                                        ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Fill="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L5,5 L10,0 Z" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC" />
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#94A3B8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="12,3,31,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"  Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="White" BorderThickness="1" CornerRadius="8" BorderBrush="#E2E8F0" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1" />
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,20,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter Property="Foreground" Value="#0263E0" />
                                <Setter Property="BorderBrush" Value="#0263E0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerOutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EF4444" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderBrush" Value="#FEE2E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FEF2F2" />
                                <Setter Property="BorderBrush" Value="#FCA5A5" />
                                <Setter Property="Foreground" Value="#B91C1C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title -->
            <RowDefinition Height="Auto" /> <!-- Tabs -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions>

        <TextBlock Text="Inventory Management" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,24" />

        <!-- Tab Header -->
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="Inventory audit" Style="{StaticResource TabButtonStyle}" Tag="Selected" Name="BtnAudit" Click="TabButton_Click" />
            <Button Content="Bulk Search" Style="{StaticResource TabButtonStyle}" Name="BtnBulk" Click="TabButton_Click" />
            <Button Content="Exclusion List" Style="{StaticResource TabButtonStyle}" Name="BtnExclusion" Click="TabButton_Click" />
        </StackPanel>

        <!-- Content Area -->
        <Border Grid.Row="2" Background="White" CornerRadius="0,12,12,12" BorderBrush="#E2E8F0" BorderThickness="1" SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.03" />
            </Border.Effect>
            <Grid x:Name="ContentArea" Margin="20">
                <!-- Inventory Audit View -->
                <Grid x:Name="AuditView" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Title/Description -->
                        <RowDefinition Height="Auto" /> <!-- Filters/Toolbar -->
                        <RowDefinition Height="Auto" /> <!-- Department Filters (Collapsible) -->
                        <RowDefinition Height="*" />    <!-- Table -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Inventory Audit" FontSize="20" FontWeight="Bold" Foreground="#1E293B" />
                        <TextBlock Text="Perform comprehensive audits of instrument and gauge inventory." Foreground="#64748B" FontSize="13" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Toolbar -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Cycle:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                            <ComboBox x:Name="ComboCycle" Width="200" SelectionChanged="FilterComboBox_SelectionChanged" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Year:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                            <ComboBox x:Name="ComboYear" Width="100" SelectionChanged="FilterComboBox_SelectionChanged" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Color:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                            <ComboBox x:Name="ComboColor" Width="120" SelectionChanged="FilterComboBox_SelectionChanged" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                            <ComboBox x:Name="ComboStatus" Width="120" SelectionChanged="FilterComboBox_SelectionChanged" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Calibration Status:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                            <ComboBox x:Name="ComboCalibrationStatus" Width="140" SelectionChanged="FilterComboBox_SelectionChanged" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <Border Background="White" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,16,8" Width="180" Height="38">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtSearch" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="12,0" FontSize="14" Tag="Search by Control No..." KeyDown="TxtSearch_KeyDown" />
                                <TextBlock Text="Search Control No..." IsHitTestVisible="False" Foreground="#94A3B8" VerticalAlignment="Center" Margin="14,0" Visibility="Collapsed" x:Name="TxtSearchPlaceholder">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Width="38" Cursor="Hand" Click="LoadAuditData_Click">
                                    <Viewbox Width="16" Height="16">
                                        <Grid Width="24" Height="24">
                                            <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" Fill="#64748B" />
                                        </Grid>
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>

                        <Button Style="{StaticResource ActionButtonStyle}" Width="150" Height="38" x:Name="BtnToggleDeptFilter" Click="BtnToggleDeptFilter_Click" Margin="0,0,12,8">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                    <Grid Width="16" Height="16">
                                        <Path Data="M11,11 L14.5,14.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        <Ellipse Width="11" Height="11" Margin="1,1,4,4" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2.5" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock x:Name="TxtToggleDeptFilter" Text="Department Filter" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ActionButtonStyle}" Width="130" Height="38" x:Name="BtnToggleMoreFilters" Click="BtnToggleMoreFilters_Click" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                    <Grid Width="24" Height="24">
                                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock Text="More Filters" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Filter Containers (Collapsible) -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <!-- Department Filters -->
                        <StackPanel x:Name="DeptFilterContainer" Visibility="Collapsed" Margin="0,0,0,16">
                            <TextBlock Text="Departments:" Margin="0,0,12,8" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" />
                            <ItemsControl x:Name="DeptFiltersItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}" 
                                                Style="{StaticResource GroupFilterButtonStyle}" 
                                                Click="DeptFilterButton_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- More Filters (Date Range) -->
                        <Border x:Name="MoreFiltersContainer" Visibility="Collapsed" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Date Range:" Margin="0,0,12,12" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" />
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="From Date" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,4" />
                                        <DatePicker x:Name="DpFrom" Width="180" Height="34" SelectedDateChanged="FilterDatePicker_SelectedDateChanged" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="To Date" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,4" />
                                        <DatePicker x:Name="DpTo" Width="180" Height="34" SelectedDateChanged="FilterDatePicker_SelectedDateChanged" />
                                    </StackPanel>
                                    <Button Content="Clear Filter" Style="{StaticResource ActionButtonStyle}" Width="110" Height="34" VerticalAlignment="Bottom" Click="BtnClearDates_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>


                    <!-- Data Table -->
                    <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                        <DataGrid x:Name="AuditDataGrid" Style="{StaticResource AuditDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Instrument Name" Binding="{Binding instrument_name}" Width="180" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTemplateColumn Header="Control No" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding control_no}" 
                                                    Click="ControlNo_Click"
                                                    Style="{StaticResource TextLinkButtonStyle}" 
                                                    Margin="16,0" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
