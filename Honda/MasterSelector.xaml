<Window x:Class="MasterSelector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Calibration Master(s)" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Select the calibration master(s) used for this calibration:" 
                   Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>

        <DataGrid x:Name="MasterGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  CanUserAddRows="False" HeadersVisibility="Column"
                  Background="White" BorderBrush="#E2E8F0" SelectionMode="Single"
                  AlternatingRowBackground="#F8FAFC" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E2E8F0">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Select" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Master Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" />
                <DataGridTextColumn Header="Master Uncertainty" Binding="{Binding MasterUncertainty, StringFormat=\{0:0.##########\}}" Width="150" IsReadOnly="True" />
                <DataGridTextColumn Header="Least Count" Binding="{Binding LeastCount}" Width="100" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnApply" Content="Apply Selection" Width="120" Height="32" 
                    Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnApply_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#3B82F6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Height="32" Margin="10,0,0,0"
                    Background="Transparent" BorderBrush="#CBD5E1" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
