<Window x:Class="Dialtestindicator100"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialtestindicator100 Calibration" Height="765" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Segoe UI Variable, Arial">
    
    <Window.Resources>
        <!-- Modern Style Definitions -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Margin="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Heading -->
                <RowDefinition Height="Auto" /> <!-- Header Info -->
                <RowDefinition Height="Auto" /> <!-- Environmental -->
                <RowDefinition Height="Auto" /> <!-- Observations Tabs -->
                <RowDefinition Height="Auto" /> <!-- Bottom tracking -->
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Dialtestindicator100" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,12" />

            <!-- Header Section -->
            <GroupBox Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Control No:" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextBox1" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource LabelStyle}" Text="Category:" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ComboBox1" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Style="{StaticResource LabelStyle}" Text="Location:" />
                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="ComboBox2" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="LC (mm):" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboBox5">
                        <ComboBoxItem Content="0.01" />
                        <ComboBoxItem Content="0.001" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource LabelStyle}" Text="Calibration Date:" />
                    <DatePicker Grid.Row="2" Grid.Column="4" x:Name="TxtCalibrationDate" VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2" Grid.Column="6" Style="{StaticResource LabelStyle}" Text="Size:" />
                    <TextBox Grid.Row="2" Grid.Column="7" x:Name="TextBox21" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Color:" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TextBoxColor" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="4" Grid.Column="3" Style="{StaticResource LabelStyle}" Text="No. of Revolution:" />
                    <ComboBox Grid.Row="4" Grid.Column="4" x:Name="ComboBoxRevolution">
                        <ComboBoxItem Content="One Revolution" IsSelected="True" />
                        <ComboBoxItem Content="Greater than one Revolution" />
                    </ComboBox>

                    <TextBlock Grid.Row="4" Grid.Column="6" Style="{StaticResource LabelStyle}" Text="Probe Length (L1):" />
                    <ComboBox Grid.Row="4" Grid.Column="7" x:Name="ComboBoxProbeSize" IsEnabled="False">
                        <ComboBoxItem Content="N/A" IsSelected="True" />
                        <ComboBoxItem Content="L1 &lt;= 35" />
                        <ComboBoxItem Content="L1 &gt; 35" />
                    </ComboBox>
                </Grid>
            </GroupBox>

            <!-- Environmental Conditions -->
            <GroupBox Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="75" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="45" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Temperature:" />
                    <TextBox Grid.Column="1" x:Name="TextBox30" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="3" Style="{StaticResource LabelStyle}" Text="Humidity:" />
                    <TextBox Grid.Column="4" x:Name="TextBox28" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="6" Style="{StaticResource LabelStyle}" Text="TMU:" />
                    <TextBox Grid.Column="7" x:Name="TextBox29" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Column="9" Style="{StaticResource LabelStyle}" Text="Depth Error:" />
                    <TextBox Grid.Column="10" x:Name="TextBox20" HorizontalAlignment="Stretch" />
                </Grid>
            </GroupBox>

            <!-- Observation Tabs -->
            <GroupBox Grid.Row="3">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Observations (mm)" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="10,0,0,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Calibration master:" VerticalAlignment="Center" />
                            <Button x:Name="BtnBrowseMasterObservation" Content="..." Width="40" Height="24" Click="BtnBrowseMasterObservation_Click" />
                        </StackPanel>
                    </Grid>

                    <!-- Selected Masters for Observation -->
                    <Border x:Name="MasterGroupBoxObservation" Visibility="Collapsed" Margin="10,0,0,10" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="ItemsControlSelectedMastersObservation">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,0" Background="#F8FAFC">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="12" />
                                                <TextBlock Text=" | " Foreground="#64748B" Margin="4,0" />
                                                <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" FontSize="12" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /><RowDefinition Height="6" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="6" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="6" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="6" />
                            <RowDefinition Height="Auto" /><RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Headers -->
                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="#E2E8F0" Padding="8" Margin="0,0,0,6" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Parameter" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="1" Text="Trial 1" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="2" Text="Trial 2" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="3" Text="Trial 3" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#334155"/>
                            </Grid>
                        </Border>

                        <!-- 1/10 Rev -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="1/10 Revolution" Style="{StaticResource LabelStyle}" FontWeight="SemiBold" />
                        <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txtObs_Obs_10_Scale_Div_1" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_10_Scale_Div_2" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_10_Scale_Div_3" Margin="4,2" />
                        </UniformGrid>

                        <!-- 1 Rev -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="One Revolution" Style="{StaticResource LabelStyle}" FontWeight="SemiBold" />
                        <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txtObs_Obs_Over_1_Rev_1" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Over_1_Rev_2" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Over_1_Rev_3" Margin="4,2" />
                        </UniformGrid>

                        <!-- Whole Range -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Whole Measuring Range" Style="{StaticResource LabelStyle}" FontWeight="SemiBold" />
                        <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txtObs_Obs_Over_Meas_Range_1" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Over_Meas_Range_2" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Over_Meas_Range_3" Margin="4,2" />
                        </UniformGrid>

                        <!-- Hysteresis -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Hysteresis / Retrace Error" Style="{StaticResource LabelStyle}" FontWeight="SemiBold" />
                        <UniformGrid Grid.Row="8" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txtObs_Obs_Hysteresis_1" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Hysteresis_2" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Hysteresis_3" Margin="4,2" />
                        </UniformGrid>

                        <!-- Repeatability -->
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Repeatability" Style="{StaticResource LabelStyle}" FontWeight="SemiBold" />
                        <UniformGrid Grid.Row="10" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txtObs_Obs_Repeatability_1" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Repeatability_2" Margin="4,2" />
                            <TextBox x:Name="txtObs_Obs_Repeatability_3" Margin="4,2" />
                        </UniformGrid>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Bottom Section -->
            <GroupBox Grid.Row="4" Margin="0,6,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Time In:" />
                        <TextBox Grid.Column="1" x:Name="TextBox24" />

                        <TextBlock Grid.Column="3" Style="{StaticResource LabelStyle}" Text="Time Out:" />
                        <TextBox Grid.Column="4" x:Name="TextBox26" />

                        <TextBlock Grid.Column="6" Style="{StaticResource LabelStyle}" Text="Total Duration:" />
                        <TextBox Grid.Column="7" x:Name="TextBox25" IsReadOnly="True" Background="#F1F5F9" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Status:" />
                        <ComboBox Grid.Column="1" x:Name="ComboBox4" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="OK" IsSelected="True" />
                            <ComboBoxItem Content="NG" />
                        </ComboBox>

                        <TextBlock Grid.Column="3" Style="{StaticResource LabelStyle}" Text="Remarks:" />
                        <TextBox Grid.Column="4" x:Name="TextBox19" HorizontalAlignment="Stretch" />
                        
                        <TextBox x:Name="TextBox27" Visibility="Collapsed" />
                    </Grid>

                    <Button Grid.Row="4" x:Name="Button2" Content="SAVE FINAL RECORD" Height="42" FontSize="15" FontWeight="SemiBold" Width="260" HorizontalAlignment="Center" Click="Button2_Click" />
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
