<Window x:Class="EventDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Details" Height="350" Width="500" 
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>

        <Style x:Key="BlueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0263E0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0252B9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#059669" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="12"
                                Margin="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.1" ShadowDepth="2" />
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" Margin="4" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMenuItem" TargetType="MenuItem">
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="border" CornerRadius="8" Margin="2" Background="Transparent" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Remarks Label -->
            <RowDefinition Height="Auto" /> <!-- Remarks Box -->
            <RowDefinition Height="*" />    <!-- Spacer -->
            <RowDefinition Height="Auto" /> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="TxtEventTitle" Grid.Row="0" Style="{StaticResource HeaderStyle}" Text="Event Details" />

        <!-- Remarks Label -->
        <TextBlock x:Name="TxtMainRemarksLabel" Grid.Row="1" Text="Remarks / Reason:" FontWeight="SemiBold" Foreground="#334155" Margin="0,10,0,8" />

        <!-- Remarks Box -->
        <Border Grid.Row="2" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Background="White" MinHeight="100" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,6">
                <StackPanel>
                    <TextBlock x:Name="TxtActionLabel" Text="Action Remarks:" FontWeight="Bold" Foreground="#475569" FontSize="13" Visibility="Collapsed" Margin="0,0,0,8" />
                    <TextBlock x:Name="TxtRemarks" Text="No remarks available." TextWrapping="Wrap" Foreground="#1E293B" FontSize="14" />
                    <Separator x:Name="SeparatorReintro" Margin="0,15" Visibility="Collapsed" IsHitTestVisible="False" BorderBrush="#E2E8F0" BorderThickness="0.5" />
                    <TextBlock x:Name="TxtReintroLabel" Text="Re-introduction Remarks:" FontWeight="Bold" Foreground="#475569" FontSize="13" Visibility="Collapsed" Margin="0,0,0,8" />
                    <TextBlock x:Name="TxtReintroRemarks" Text="" TextWrapping="Wrap" Foreground="#1E293B" FontSize="14" Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="BtnViewDoc" Content="View Document" Style="{StaticResource GreenButtonStyle}" Margin="0,0,12,0" Visibility="Collapsed" Click="BtnViewDoc_Click" />
            <Button x:Name="BtnClose" Content="Close" Style="{StaticResource BlueButtonStyle}" Width="100" Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
