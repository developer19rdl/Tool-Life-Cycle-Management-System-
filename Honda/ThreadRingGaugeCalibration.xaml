<Window x:Class="ThreadRingGaugeCalibration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="Thread Ring Gauge Calibration" Height="765" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Arial">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <ContentPresenter Margin="12,10" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16,10" x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Device Info -->
            <RowDefinition Height="Auto" /> <!-- Environment -->
            <RowDefinition Height="Auto" /> <!-- Masters Cache -->
            <RowDefinition Height="Auto" /> <!-- Observations -->
            <RowDefinition Height="Auto" /> <!-- Soaking / Judgement -->
            <RowDefinition Height="Auto" /> <!-- Submit Button -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Thread Ring Gauge Calibration" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
        </Grid>

        <!-- Device Info -->
        <GroupBox Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="85"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Control No :" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtControlNo" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Category/Control :" />
                <ComboBox Grid.Row="0" Grid.Column="4" x:Name="ComboCategory" IsEnabled="False" />

                <TextBlock Grid.Row="0" Grid.Column="6" Text="Calibration Date :" />
                <DatePicker Grid.Row="0" Grid.Column="7" x:Name="TxtCalibrationDate" Height="30" VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Colour :" />
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboColour" IsEditable="True" />

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Location :" />
                <ComboBox Grid.Row="2" Grid.Column="4" x:Name="ComboLocation" IsEditable="True" />

                <TextBlock Grid.Row="2" Grid.Column="6" Text="LC :" />
                <ComboBox Grid.Row="2" Grid.Column="7" x:Name="ComboLC" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Calibration Master:" />
                <Button Grid.Row="4" Grid.Column="1" x:Name="BtnBrowseMaster" Content="Select Master(s)" Click="BtnBrowseMaster_Click" Height="30"/>
            </Grid>
        </GroupBox>

        <!-- Environment -->
        <GroupBox Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="85"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Temp (°C) :" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTemp" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Humidity (%) :" />
                <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtHumidity" />

                <TextBlock Grid.Row="0" Grid.Column="6" Text="TMU :" />
                <TextBox Grid.Row="0" Grid.Column="7" x:Name="TxtTMU" IsReadOnly="True" Background="#F1F5F9" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="MU :" />
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMU" ToolTip="Enter Master Uncertainty (MU) manually. TMU will be recalculated automatically." />
            </Grid>
        </GroupBox>

        <!-- Selected Calibration Masters (Dynamic Section) -->
        <GroupBox x:Name="MasterGroupBox" Grid.Row="3" Visibility="Collapsed" Margin="0,4">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="ItemsControlSelectedMasters">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="10,4" Margin="0,0,8,4" Background="#F8FAFC">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="12" />
                                    <TextBlock Text=" | " Foreground="#64748B" Margin="5,0" />
                                    <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <!-- Observations -->
        <GroupBox Header="Observations" Grid.Row="4" Margin="0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <!-- Size -->
                        <ColumnDefinition Width="3.5*"/>
                        <ColumnDefinition Width="15"/>
                        <!-- Min -->
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="15"/>
                        <!-- Max -->
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="15"/>
                        <!-- Trial 1 -->
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="15"/>
                        <!-- Trial 2 -->
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="15"/>
                        <!-- Trial 3 -->
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Headers -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Size" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Min Limit" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Max Limit" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Trial 1 (µm)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="8" Text="Trial 2 (µm)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="10" Text="Trial 3 (µm)" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4" HorizontalAlignment="Center"/>

                    <!-- Inputs -->
                    <TextBox Grid.Row="1" Grid.Column="0" x:Name="TxtSize" />
                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="TxtMin" />
                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="TxtMax" />
                    <TextBox Grid.Row="1" Grid.Column="6" x:Name="TxtObs1" />
                    <TextBox Grid.Row="1" Grid.Column="8" x:Name="TxtObs2" />
                    <TextBox Grid.Row="1" Grid.Column="10" x:Name="TxtObs3" />
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Soaking / Judgement -->
        <GroupBox Grid.Row="5" Margin="0,4,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="85"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Time In:" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTimeIn" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Time Out:" />
                <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtTimeOut" />

                <TextBlock Grid.Row="0" Grid.Column="6" Text="Total Time:" />
                <TextBox Grid.Row="0" Grid.Column="7" x:Name="TxtTotalTime" IsReadOnly="True" Background="#F1F5F9" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Judgement:" />
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboJudgement">
                    <ComboBoxItem Content="OK"/>
                    <ComboBoxItem Content="NG"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Remark :" />
                <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtRemark" />

                <TextBlock Grid.Row="2" Grid.Column="6" Text="Parameters :" />
                <TextBox Grid.Row="2" Grid.Column="7" Text="Effective Diameter" IsReadOnly="True" Background="#F1F5F9" />
            </Grid>
        </GroupBox>

        <!-- Submit Button -->
        <Button Grid.Row="6" Content="Submit" Width="220" Height="36" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" x:Name="BtnUpdate" Click="BtnUpdate_Click"/>
    </Grid>
</Window>
