<Window x:Class="ResetInterchangeabilityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Reset Interchangeability" Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F1F5F9"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" />
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Reset Interchangeability" FontSize="20" FontWeight="Bold" Foreground="#1E293B" />
                <TextBlock Text="Choose the scope of the reset action:" FontSize="13" Foreground="#64748B" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Options -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <RadioButton x:Name="RadioCurrentCycle" GroupName="ResetScope" IsChecked="True" Margin="0,0,0,15" Content="[Cycle]">
                    <RadioButton.Template>
                        <ControlTemplate TargetType="RadioButton">
                            <BulletDecorator Background="Transparent" Cursor="Hand">
                                <BulletDecorator.Bullet>
                                    <Grid Width="18" Height="18">
                                        <Ellipse x:Name="OuterEllipse" Stroke="#CBD5E1" StrokeThickness="1" Fill="White" />
                                        <Ellipse x:Name="InnerEllipse" Fill="#3B82F6" Width="10" Height="10" Visibility="Collapsed" />
                                    </Grid>
                                </BulletDecorator.Bullet>
                                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Current cycle (" FontSize="15" Foreground="#1E293B" />
                                    <TextBlock Text="{TemplateBinding Content}" FontWeight="SemiBold" FontSize="15" Foreground="#1E293B" />
                                    <TextBlock Text=")" FontSize="15" Foreground="#1E293B" />
                                </StackPanel>
                            </BulletDecorator>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="OuterEllipse" Property="Stroke" Value="#3B82F6" />
                                    <Setter TargetName="InnerEllipse" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RadioButton.Template>
                </RadioButton>

                <RadioButton x:Name="RadioAll" GroupName="ResetScope">
                    <RadioButton.Template>
                        <ControlTemplate TargetType="RadioButton">
                            <BulletDecorator Background="Transparent" Cursor="Hand">
                                <BulletDecorator.Bullet>
                                    <Grid Width="18" Height="18">
                                        <Ellipse x:Name="OuterEllipse" Stroke="#CBD5E1" StrokeThickness="1" Fill="White" />
                                        <Ellipse x:Name="InnerEllipse" Fill="#3B82F6" Width="10" Height="10" Visibility="Collapsed" />
                                    </Grid>
                                </BulletDecorator.Bullet>
                                <TextBlock Margin="10,0,0,0" FontSize="15" Foreground="#1E293B" VerticalAlignment="Center">
                                    <Run Text="All" /><Run Foreground="#EF4444" Text=" (Full System Reset)" />
                                </TextBlock>
                            </BulletDecorator>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="OuterEllipse" Property="Stroke" Value="#3B82F6" />
                                    <Setter TargetName="InnerEllipse" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RadioButton.Template>
                </RadioButton>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,12,0" Background="Transparent" Foreground="#64748B" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Padding="12,8">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Submit" Click="BtnSubmit_Click" Width="100" Height="38" FontWeight="Bold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="#3B82F6" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2563EB" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
