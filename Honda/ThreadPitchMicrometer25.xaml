<Window x:Class="ThreadPitchMicrometer25"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="Thread Pitch Micrometer 0-25 mm" Height="850" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Segoe UI Variable, Arial">

    <!-- Global Styles -->
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Margin="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Row 0: Heading -->
                <RowDefinition Height="Auto" /> <!-- Row 1: Header Section -->
                <RowDefinition Height="Auto" /> <!-- Row 2: Environmental Conditions -->
                <RowDefinition Height="Auto" /> <!-- Row 3: Selected Calibration Masters -->
                <RowDefinition Height="Auto" /> <!-- Row 4: Observations Panel -->
                <RowDefinition Height="Auto" /> <!-- Row 5: Bottom Utility Panel -->
            </Grid.RowDefinitions>

            <!-- Top Left Heading -->
            <TextBlock Grid.Row="0" Text="Thread Pitch Micrometer 0-25 mm" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10" HorizontalAlignment="Left" />

            <!-- Header and Base Details -->
            <GroupBox Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="85"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Control No:" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextBox1" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Category:" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ComboBox1" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Location:" />
                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="ComboBox2" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="LC (mm):" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboBox5" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="0.001" />
                        <ComboBoxItem Content="0.010" />
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Calibration Date:" />
                    <DatePicker Grid.Row="2" Grid.Column="4" x:Name="TxtCalibrationDate" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2" Grid.Column="6" Text="Size:" />
                    <ComboBox Grid.Row="2" Grid.Column="7" x:Name="TextBox21" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Color:" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TextBoxColor" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Calibration master:" />
                    <Grid Grid.Row="4" Grid.Column="4">
                        <Button x:Name="BtnBrowseMaster" Content="..." Width="60" Height="26" HorizontalAlignment="Left" Click="BtnBrowseMaster_Click" />
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Environmental Conditions -->
            <GroupBox Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="75" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="45" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="85" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Temperature:" />
                    <TextBox Grid.Column="1" x:Name="TextBox30" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="3" Text="Humidity:" />
                    <TextBox Grid.Column="4" x:Name="TextBox28" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="6" Text="TMU:" />
                    <TextBox Grid.Column="7" x:Name="TextBox29" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="9" Text="Depth Error:" />
                    <TextBox Grid.Column="10" x:Name="TextBox20" HorizontalAlignment="Stretch" />
                </Grid>
            </GroupBox>

            <!-- Selected Calibration Masters -->
            <GroupBox x:Name="MasterGroupBox" Grid.Row="3" Visibility="Collapsed" Margin="0,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsControlSelectedMasters">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="12,6" Margin="0,0,10,6" Background="#F8FAFC">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" />
                                        <TextBlock Text=" | " Foreground="#64748B" Margin="6,0" />
                                        <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- Observations Grid -->
            <GroupBox Grid.Row="4">
                <StackPanel>
                    <TextBlock Text="Observations" FontWeight="Bold" FontSize="16" Margin="0,0,0,16" Foreground="Black"/>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="Auto" MinWidth="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 0: 2.500 and 15.000 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="2.500 mm:" x:Name="Label2_5" />
                        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt2_5_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt2_5_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt2_5_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <TextBlock Grid.Row="0" Grid.Column="3" Text="15.000 mm:" x:Name="Label15_0" />
                        <UniformGrid Grid.Row="0" Grid.Column="4" Columns="3">
                            <TextBox x:Name="txt15_0_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt15_0_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt15_0_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <!-- Row 2: 5.100 and 17.600 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="5.100 mm:" x:Name="Label5_1" />
                        <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt5_1_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt5_1_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt5_1_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <TextBlock Grid.Row="2" Grid.Column="3" Text="17.600 mm:" x:Name="Label17_6" />
                        <UniformGrid Grid.Row="2" Grid.Column="4" Columns="3">
                            <TextBox x:Name="txt17_6_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt17_6_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt17_6_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <!-- Row 4: 7.700 and 20.200 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="7.700 mm:" x:Name="Label7_7" />
                        <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt7_7_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt7_7_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt7_7_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <TextBlock Grid.Row="4" Grid.Column="3" Text="20.200 mm:" x:Name="Label20_2" />
                        <UniformGrid Grid.Row="4" Grid.Column="4" Columns="3">
                            <TextBox x:Name="txt20_2_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt20_2_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt20_2_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <!-- Row 6: 10.300 and 22.800 -->
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="10.300 mm:" x:Name="Label10_3" />
                        <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt10_3_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt10_3_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt10_3_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <TextBlock Grid.Row="6" Grid.Column="3" Text="22.800 mm:" x:Name="Label22_8" />
                        <UniformGrid Grid.Row="6" Grid.Column="4" Columns="3">
                            <TextBox x:Name="txt22_8_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt22_8_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt22_8_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <!-- Row 8: 12.900 and 25.000 -->
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="12.900 mm:" x:Name="Label12_9" />
                        <UniformGrid Grid.Row="8" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt12_9_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt12_9_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt12_9_3" Margin="4,0,0,0" />
                        </UniformGrid>

                        <TextBlock Grid.Row="8" Grid.Column="3" Text="25.000 mm:" x:Name="Label25_0" />
                        <UniformGrid Grid.Row="8" Grid.Column="4" Columns="3">
                            <TextBox x:Name="txt25_0_1" Margin="0,0,4,0" />
                            <TextBox x:Name="txt25_0_2" Margin="2,0,2,0" />
                            <TextBox x:Name="txt25_0_3" Margin="4,0,0,0" />
                        </UniformGrid>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Bottom Tracking Details -->
            <GroupBox Grid.Row="5" Margin="0,6,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Time In:" />
                        <TextBox Grid.Column="1" x:Name="TextBox24" HorizontalAlignment="Stretch" />

                        <TextBlock Grid.Column="3" Text="Time Out:" />
                        <TextBox Grid.Column="4" x:Name="TextBox26" HorizontalAlignment="Stretch" />

                        <TextBlock Grid.Column="6" Text="Total Duration:" />
                        <TextBox Grid.Column="7" x:Name="TextBox25" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Status:" />
                        <ComboBox Grid.Column="1" x:Name="ComboBox4" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="OK" />
                            <ComboBoxItem Content="NG" />
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Remarks:" />
                        <TextBox Grid.Column="4" x:Name="TextBox19" HorizontalAlignment="Stretch" />
                    </Grid>

                    <Button Grid.Row="6" x:Name="Button2" Content="SAVE FINAL RECORD" Height="42" FontSize="15" FontWeight="Bold" Width="260" HorizontalAlignment="Center" />
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
