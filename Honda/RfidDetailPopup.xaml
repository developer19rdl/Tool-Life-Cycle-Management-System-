<Window x:Class="RfidDetailPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tools Identified" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="1"
        BorderBrush="#E2E8F0">
    
    <Window.Resources>
        <Style x:Key="BlueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0263E0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0252B9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeight" Value="50" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Margin" Value="0,2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="12,0" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Direction="270" Opacity="0.15" ShadowDepth="4"/>
        </Border.Effect>
        
        <Grid Margin="24" Background="Transparent" MouseDown="RootGrid_MouseDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="TOOLS IDENTIFIED" FontSize="11" FontWeight="Bold" Foreground="#0263E0" Margin="0,0,0,4" />
                <TextBlock x:Name="TxtCountHeader" Text="3 Tools Found" FontSize="24" FontWeight="Bold" Foreground="#0F172A" />
            </StackPanel>

            <!-- Grid Area -->
            <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="12" Padding="8">
                <DataGrid x:Name="DgResults" Style="{StaticResource ModernDataGrid}" 
                          HorizontalScrollBarVisibility="Visible"
                          ScrollViewer.CanContentScroll="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CONTROL NO" Binding="{Binding ControlNumber}" Width="120" />
                        <DataGridTextColumn Header="TOOL NAME" Binding="{Binding Name}" Width="200" />
                        <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="100" />
                        <DataGridTextColumn Header="COLOUR" Binding="{Binding Colour}" Width="100" />
                        <DataGridTextColumn Header="RFID (EPC)" Binding="{Binding Rfid}" Width="350" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Actions -->
            <Button x:Name="BtnClose" Grid.Row="2" Content="Dismiss" Style="{StaticResource BlueButtonStyle}" HorizontalAlignment="Right" Margin="0,24,0,0" Width="120" Click="BtnClose_Click" />
        </Grid>
    </Border>
</Window>
