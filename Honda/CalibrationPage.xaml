<Page x:Class="CalibrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Calibration"
      Background="#F1F5F9"
      UseLayoutRounding="True"
      TextOptions.TextFormattingMode="Display">

    <Page.Resources>
        <Style x:Key="CalibrationCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="15,25" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Width" Value="250" />
            <Setter Property="BorderBrush" Value="#0263E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.05" />
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CalibrationCardTemplate">
            <Border Style="{StaticResource CalibrationCardStyle}" 
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="Card_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="{Binding instrument_name}" 
                               FontWeight="Bold" 
                               FontSize="15" 
                               Foreground="#1E293B" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               TextAlignment="Center" />
                </DockPanel>
            </Border>
        </DataTemplate>
        
        <DataTemplate x:Key="MasterCardTemplate">
            <Border Style="{StaticResource CalibrationCardStyle}" 
                    Cursor="Hand"
                    PreviewMouseLeftButtonDown="MasterCard_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="{Binding instrument_name}" 
                               FontWeight="Bold" 
                               FontSize="15" 
                               Foreground="#1E293B" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               TextAlignment="Center" />
                </DockPanel>
            </Border>
        </DataTemplate>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="30,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6,6,0,0" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#0263E0" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3B82F6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- New DataGrid Styles for Consistency -->
        <Style x:Key="CalibrationDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="ColumnHeaderHeight" Value="45" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="Selector.IsSelectionActive" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#0263E0" />
                    <Setter Property="Foreground" Value="White" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridCellTextBlockStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True" />
                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="White" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TextLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#0263E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2563EB"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <Setter Property="Foreground" Value="#98AFC7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1E293B" />
                                <Setter Property="BorderBrush" Value="#E2E8F0" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter Property="Foreground" Value="#0263E0" />
                                <Setter Property="BorderBrush" Value="#0263E0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Consistent ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        Background="{TemplateBinding Background}" 
                                        Grid.Column="2" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                        Focusable="false"
                                        ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Fill="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M0,0 L5,5 L10,0 Z" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC" />
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#94A3B8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="12,3,31,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True"  Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="White" BorderThickness="1" CornerRadius="8" BorderBrush="#E2E8F0" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.1" />
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title -->
            <RowDefinition Height="Auto" /> <!-- Tabs -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions>

        <TextBlock Text="Calibration" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,24" />

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="Regular calibration" Style="{StaticResource TabButtonStyle}" Tag="Selected" Name="BtnRegularCalib" Click="TabButton_Click" />
            <Button Content="New Edition Calibration" Style="{StaticResource TabButtonStyle}" Name="BtnNewEditionCalib" Click="TabButton_Click" />
            <Button Content="Reintroduction" Style="{StaticResource TabButtonStyle}" Name="BtnReintroduction" Click="TabButton_Click" />
            <Button Content="Temp Issuance" Style="{StaticResource TabButtonStyle}" Name="BtnTempIssuance" Click="TabButton_Click" />
            <Button Content="Calibration Master" Style="{StaticResource TabButtonStyle}" Name="BtnCalibrationMaster" Click="TabButton_Click" />
            <Button Content="NG List" Style="{StaticResource TabButtonStyle}" Name="BtnNGList" Click="TabButton_Click" />
            <Button Content="Test" Style="{StaticResource TabButtonStyle}" Name="BtnTest" Click="TabButton_Click" />
        </StackPanel>

        <!-- Content Area -->
        <Border Grid.Row="2" Background="White" CornerRadius="0,12,12,12" BorderBrush="#E2E8F0" BorderThickness="1" SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.03" />
            </Border.Effect>
            <Grid x:Name="CalibrationContentArea" Margin="20">
                <!-- Regular Calibration Tab View -->
                <Grid x:Name="RegularCalibTabView" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Sub Tabs -->
                        <RowDefinition Height="*" />    <!-- Content Area -->
                    </Grid.RowDefinitions>

                    <!-- Sub Navigation -->
                    <Border Grid.Row="0" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Calibration Status" Style="{StaticResource SubTabButtonStyle}" Tag="Selected" Name="BtnStatusTab" Click="SubTabButton_Click" />
                            <Button Content="Instrument Calibration" Style="{StaticResource SubTabButtonStyle}" Name="BtnInstrumentTab" Click="SubTabButton_Click" />
                            <Button Content="Gauge Calibration" Style="{StaticResource SubTabButtonStyle}" Name="BtnGaugeTab" Click="SubTabButton_Click" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- Calibration Status Content -->
                        <Grid x:Name="StatusTabView" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="Cycle:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                                    <ComboBox x:Name="ComboCycle" Width="280" SelectionChanged="ComboCycle_SelectionChanged" VerticalAlignment="Center" />
                                    <Button x:Name="BtnImportRegularCalib" Content="Import Data" Style="{StaticResource ActionButtonStyle}" Margin="10,0,0,0" Height="34" Width="100" Click="BtnImportRegularCalib_Click" IsEnabled="False" />
                                </StackPanel>
                                
                                <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="View Result" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="34" x:Name="BtnViewResult" Click="BtnViewResult_Click" Visibility="Collapsed" />
                            </DockPanel>

                            <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                                <DataGrid x:Name="RegularCalibDataGrid" Style="{StaticResource CalibrationDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Instrument Name" Binding="{Binding instrument_name}" Width="200" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTemplateColumn Header="Control No" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding control_no}" 
                                                            Click="ControlNo_Click"
                                                            Style="{StaticResource TextLinkButtonStyle}" 
                                                            Margin="16,0" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Status" Binding="{Binding status}" Width="120" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibrated" Binding="{Binding is_calibrated}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibrated Date" Binding="{Binding calibrated_date, StringFormat=\{0:dd/MM/yyyy\}}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibration Due Date" Binding="{Binding due_date, StringFormat=\{0:dd/MM/yyyy\}}" Width="180" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibration Status" Binding="{Binding calibration_status}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>

                        <!-- Instrument Calibration Content -->
                        <Grid x:Name="InstrumentTabView" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="InstrumentCardsControl" ItemTemplate="{StaticResource CalibrationCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Margin="5" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                        
                        <!-- Gauge Calibration Content -->
                        <Grid x:Name="GaugeTabView" Visibility="Collapsed">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="GaugeCardsControl" ItemTemplate="{StaticResource CalibrationCardTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Margin="5" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <!-- Card Detail View Content (Hidden by default) -->
                        <Grid x:Name="CardDetailTabView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <Button x:Name="BtnBackToCards" Click="BtnBackToCards_Click" Style="{StaticResource ActionButtonStyle}" Width="40" Height="34" Margin="0,0,15,0" Padding="0">
                                        <TextBlock Text="←" FontWeight="Bold" FontSize="20" Margin="0,-2,0,0" />
                                    </Button>
                                    <TextBlock x:Name="TxtDetailTitle" Text="Instrument Details" FontWeight="Bold" FontSize="18" Foreground="#1E293B" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right" 
                                        Content="View Result" 
                                        Style="{StaticResource PrimaryButtonStyle}" 
                                        Width="120"
                                        Height="34"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        x:Name="BtnViewGroupResult"
                                        Click="BtnViewGroupResult_Click"/>
                            </DockPanel>

                            <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                                <DataGrid x:Name="DetailCalibDataGrid" Style="{StaticResource CalibrationDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Instrument Name" Binding="{Binding instrument_name}" Width="200" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTemplateColumn Header="Control No" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding control_no}" 
                                                            Click="ControlNo_Click"
                                                            Style="{StaticResource TextLinkButtonStyle}" 
                                                            Margin="16,0" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Status" Binding="{Binding status}" Width="120" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibrated" Binding="{Binding is_calibrated}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibrated Date" Binding="{Binding calibrated_date, StringFormat=\{0:dd/MM/yyyy\}}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibration Due Date" Binding="{Binding due_date, StringFormat=\{0:dd/MM/yyyy\}}" Width="180" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTextColumn Header="Calibration Status" Binding="{Binding calibration_status}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- New Edition Calibration Tab View -->
                <Grid x:Name="NewEditionCalibTabView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Calibration Status" Style="{StaticResource SubTabButtonStyle}" Tag="Selected" Name="BtnNewEditionStatusTab" Click="SubTabButton_Click" />
                            <Button Content="Instrument Calibration" Style="{StaticResource SubTabButtonStyle}" Name="BtnNewEditionInstrumentTab" Click="SubTabButton_Click" />
                            <Button Content="Gauge Calibration" Style="{StaticResource SubTabButtonStyle}" Name="BtnNewEditionGaugeTab" Click="SubTabButton_Click" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid x:Name="NewEditionStatusTabView" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="Cycle:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#64748B" />
                                    <ComboBox x:Name="ComboNewEditionCycle" Width="280" SelectionChanged="ComboCycle_SelectionChanged" VerticalAlignment="Center" />
                                    <TextBlock Text="Request No:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0,10,0" Foreground="#64748B" />
                                    <ComboBox x:Name="ComboNewEditionRequestFilter" Width="200" VerticalAlignment="Center" SelectionChanged="ComboNewEditionRequestFilter_SelectionChanged" />
                                </StackPanel>
                                
                                <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Content="View Result" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="34" x:Name="BtnNewEditionViewResult" Click="BtnViewResult_Click" Visibility="Collapsed" />
                            </DockPanel>

                            <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                                <DataGrid x:Name="NewEditionCalibDataGrid" Style="{StaticResource CalibrationDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Instrument Name" Binding="{Binding instrument_name}" Width="200" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                        <DataGridTemplateColumn Header="Control No" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding control_no}" 
                                                            Click="ControlNo_Click"
                                                            Style="{StaticResource TextLinkButtonStyle}" 
                                                            Margin="16,0" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Request No" Binding="{Binding RequestNo}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
