                                                        <Button Margin="2" Click="Button_TPM100_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Thread Pitch Micrometer 100mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="9.5" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Point25_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Point Micrometer 25mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Point50_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Point Micrometer 50mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Inside25_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Inside Micrometer 25mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Inside50_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Inside Micrometer 50mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Groove25_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Groove Micrometer 25mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Groove50_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Groove Micrometer 50mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_Geartooth50_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="Gear Tooth Micrometer 50mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="9.5" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_ExtMic100_Click" Style="{StaticResource ActionButtonStyle}" Height="38">
                                                            <TextBlock Text="External Micrometer 100mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="9.5" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_DiscMic_Click" Style="{StaticResource ActionButtonStyle}" Height="38" Background="#EFF6FF" BorderBrush="#BFDBFE" Foreground="#1E40AF">
                                                            <TextBlock Text="Disc Micrometer 75mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_DepthMic_Click" Style="{StaticResource ActionButtonStyle}" Height="38" Background="#F0FDF4" BorderBrush="#BBF7D0" Foreground="#166534">
                                                            <TextBlock Text="Depth Micrometer 150mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_BladeMic_Click" Style="{StaticResource ActionButtonStyle}" Height="38" Background="#FFF1F2" BorderBrush="#FECDD3" Foreground="#9F1239">
                                                            <TextBlock Text="Blade Micrometer 75mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="10" />
                                                        </Button>
                                                        <Button Margin="2" Click="Button_BoreGauge_Click" Style="{StaticResource ActionButtonStyle}" Height="38" Background="#F5F3FF" BorderBrush="#DDD6FE" Foreground="#5B21B6">
                                                            <TextBlock Text="Bore Gauge 3" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                        </Button>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </UniformGrid>

                                            <!-- Specialized Instruments -->
                                            <TextBlock Text="Specialized Tools" FontSize="14" FontWeight="Bold" Foreground="#475569" Margin="10,15,0,10" />
                                            <UniformGrid Columns="2" Margin="5,0">
                                                <Button Click="Button_HeightGauge600_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#EFF6FF" Foreground="#1E40AF" BorderBrush="#BFDBFE">
                                                    <TextBlock Text="Height Gauge 600mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_Passameter60_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F5F3FF" Foreground="#5B21B6" BorderBrush="#DDD6FE">
                                                    <TextBlock Text="Passameter 60mm" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_DialGuage100_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#FFFBEB" Foreground="#92400E" BorderBrush="#FEF3C7">
                                                    <TextBlock Text="DialGuage 100" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                            </UniformGrid>
                                        </StackPanel>

                                        <!-- Gauges Panel -->
                                        <StackPanel x:Name="TestGaugesPanel" Visibility="Collapsed" Margin="0,0,10,0">
                                            <TextBlock Text="Gauge Calibration" FontSize="14" FontWeight="Bold" Foreground="#475569" Margin="10,10,0,10" />
                                            <UniformGrid Columns="2" Margin="5,0">
                                                <Button Click="Button_HeightMaster_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0">
                                                    <TextBlock Text="Height Master" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_KeyGrooveGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#FFF1F2" Foreground="#9F1239" BorderBrush="#FECDD3">
                                                    <TextBlock Text="Key Groove Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_PlainPlugGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0">
                                                    <TextBlock Text="Plain Plug Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_PlainRingGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#EFF6FF" Foreground="#1E40AF" BorderBrush="#BFDBFE">
                                                    <TextBlock Text="Plain Ring Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_SnapGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#FFFBEB" Foreground="#92400E" BorderBrush="#FEF3C7">
                                                    <TextBlock Text="Snap Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_SpecialHeightGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F5F3FF" Foreground="#5B21B6" BorderBrush="#DDD6FE">
                                                    <TextBlock Text="Special Height Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_SplineRingGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0">
                                                    <TextBlock Text="Spline Ring Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                <Button Click="Button_StraightPlugGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#FFFBEB" Foreground="#92400E" BorderBrush="#FEF3C7">
                                                    <TextBlock Text="Straight Plug Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                </Button>
                                                 <Button Click="Button_ThreadRingGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#EFF6FF" Foreground="#1E40AF" BorderBrush="#BFDBFE">
                                                     <TextBlock Text="Thread Ring Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                 </Button>
                                                 <Button Click="Button_ThreadPlugGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F5F3FF" Foreground="#5B21B6" BorderBrush="#DDD6FE">
                                                     <TextBlock Text="Thread Plug Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                 </Button>
                                                 <Button Click="Button_TaperPlugGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#FFFBEB" Foreground="#92400E" BorderBrush="#FEF3C7">
                                                     <TextBlock Text="Taper Plug Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                 </Button>
                                                 <Button Click="Button_TaperRingGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#EFF6FF" Foreground="#1E40AF" BorderBrush="#BFDBFE">
                                                     <TextBlock Text="Taper Ring Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                 </Button>
                                                 <Button Click="Button_FeelerGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0">
                                                     <TextBlock Text="Feeler Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                 </Button>
                                                 <Button Click="Button_RadiusGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#FFF1F2" Foreground="#9F1239" BorderBrush="#FECDD3">
                                                     <TextBlock Text="Radius Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                 </Button>
                                                  <Button Click="Button_ThreadPitchGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F5F3FF" Foreground="#5B21B6" BorderBrush="#DDD6FE">
                                                      <TextBlock Text="Thread Pitch Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                  </Button>
                                                  <Button Click="Button_SpecialDepthGauge_Click" Style="{StaticResource ActionButtonStyle}" Margin="5" Height="42" Background="#F0FDF4" Foreground="#166534" BorderBrush="#BBF7D0">
                                                      <TextBlock Text="Special Depth Gauge" TextWrapping="Wrap" TextAlignment="Center" FontSize="12" />
                                                  </Button>
                                            </UniformGrid>
                                            <TextBlock Text="* Standard plug, ring, and thread gauges are calibrated directly from the 'Status' tab by clicking their Control Number." FontSize="11" Foreground="#94A3B8" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="450"/>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                <!-- NG List Tab View -->
                <Grid x:Name="NGListTabView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="NG List" FontWeight="Bold" FontSize="18" Foreground="#1E293B" VerticalAlignment="Center" />
                    </DockPanel>

                    <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
                        <DataGrid x:Name="NGListDataGrid" Style="{StaticResource CalibrationDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Instrument Name" Binding="{Binding instrument_name}" Width="200" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTextColumn Header="Control No" Binding="{Binding control_no}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTextColumn Header="Calibrated Date" Binding="{Binding calibrated_date, StringFormat={}{0:dd-MM-yyyy}}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTextColumn Header="Due Date" Binding="{Binding due_date, StringFormat={}{0:dd-MM-yyyy}}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTextColumn Header="Status" Binding="{Binding status}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                                <DataGridTextColumn Header="Reason" Binding="{Binding reason}" Width="*" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
