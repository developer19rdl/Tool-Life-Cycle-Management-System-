<Page x:Class="GaugeManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Gauge Management"
      Background="#F1F5F9">

    <Page.Resources>
        <!-- Reusing styles from Form16 for consistency -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                                <Setter Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaginationButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0" />
        </Style>

        <Style x:Key="GroupFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,4" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="60" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#0263E0" />
                                <Setter TargetName="border" Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" x:Name="border">
                            <Path Data="M20,12 L10,12 M14,8 L10,12 L14,16" 
                                  Stroke="{TemplateBinding Foreground}" 
                                  StrokeThickness="2" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DataGridCellTextBlockStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True" />
                        <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="White" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="24" Background="Transparent" MouseDown="RootGrid_MouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Toolbar & Filters -->
            <RowDefinition Height="*" />    <!-- Data Table -->
            <RowDefinition Height="Auto" /> <!-- Pagination -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,24">
            <Button x:Name="BtnBack" Style="{StaticResource BackButtonStyle}" Click="BtnBack_Click" Margin="0,0,16,0" VerticalAlignment="Center" ToolTip="Go Back to Category Selection" />
            <TextBlock x:Name="TxtHeaderTitle" Text="Gauge Management" FontSize="28" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Toolbar & Filters -->
        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,24" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" />
            </Border.Effect>
            <StackPanel>
                <!-- Actions Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <Button Content="➕ Add" Style="{StaticResource PrimaryButtonStyle}" Width="100" x:Name="BtnAdd" />
                        <Button Content="📥 Download" Style="{StaticResource ActionButtonStyle}" Width="120" x:Name="BtnDownload" />
                        <Button Content="✏️ Edit" Style="{StaticResource ActionButtonStyle}" Width="100" x:Name="BtnEdit" />
                        <Button Content="🗑️ Delete" Style="{StaticResource ActionButtonStyle}" Width="100" x:Name="BtnDelete" />
                        <Button Content="📤 Import" Style="{StaticResource ActionButtonStyle}" Width="100" x:Name="BtnImport" />
                        <ProgressBar Width="120" Height="8" VerticalAlignment="Center" Margin="8,0,0,0" x:Name="MainProgressBar" Foreground="Green" Visibility="Collapsed" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Grid.Column="1">
                        <TextBox Width="200" x:Name="TxtSearch" Tag="Search gauges..." />
                        <Button Style="{StaticResource ActionButtonStyle}" Width="40" Margin="4,0,0,0" x:Name="BtnSearch">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="16" Height="16">
                                    <Path Data="M11,11 L14.5,14.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Ellipse Width="11" Height="11" Margin="1,1,4,4" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2.5" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Filters Row -->
                <UniformGrid Columns="5">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Line" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" />
                        <ComboBox x:Name="ComboLine" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Section" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" />
                        <ComboBox x:Name="ComboSection" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Location" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" />
                        <ComboBox x:Name="ComboLocation" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Size" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" />
                        <ComboBox x:Name="ComboSize" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Status" Margin="0,0,0,6" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" />
                        <ComboBox x:Name="ComboStatus" />
                    </StackPanel>
                </UniformGrid>

                <!-- Groups Row -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Groups:" Margin="0,0,12,0" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" />
                    <ItemsControl Grid.Column="1" x:Name="GroupsItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" 
                                        Style="{StaticResource GroupFilterButtonStyle}" 
                                        Click="GroupButton_Click" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Data Table -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="GaugesDataGrid" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      BorderThickness="0" 
                      Background="Transparent"
                      RowHeight="40"
                      ColumnHeaderHeight="45"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      ContextMenuOpening="GaugesDataGrid_ContextMenuOpening">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC" />
                        <Setter Property="Foreground" Value="#64748B" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="16,0" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="#E2E8F0" />
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="Selector.IsSelectionActive" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#0263E0" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Writeoff" x:Name="MenuWriteOff" Click="MenuWriteOff_Click" />
                        <MenuItem Header="View History" x:Name="MenuMenuView" Click="MenuMenuView_Click" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50" IsReadOnly="True" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTemplateColumn Header="Control No" Width="120" SortMemberPath="ControlNo">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="SemiBold" 
                                           Cursor="Hand" 
                                           MouseLeftButtonDown="ControlNo_MouseLeftButtonDown">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextBlockStyle}">
                                            <Setter Property="Foreground" Value="#3B82F6" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextDecorations" Value="Underline" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                    <Setter Property="Foreground" Value="#98AFC7" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding ControlNo}" />
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Gauge Name" Binding="{Binding GaugeName}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Description" Binding="{Binding GaugeDescription}" Width="200" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="80" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Category" Binding="{Binding CategoryControl}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Drg No" Binding="{Binding DrgNo}" Width="120" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Model No" Binding="{Binding Model}" Width="120" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="80" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Tol" Binding="{Binding Tol}" Width="80" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Tol 2" Binding="{Binding Tol2}" Width="80" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Tol 3" Binding="{Binding Tol3}" Width="80" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Maker Name" Binding="{Binding MakerName}" Width="120" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Request No" Binding="{Binding RequestNo}" Width="100" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                    <DataGridTextColumn Header="Remark" Binding="{Binding Remark}" Width="150" ElementStyle="{StaticResource DataGridCellTextBlockStyle}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Pagination -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <TextBlock x:Name="LblPageInfo" Text="Page 1 of 10" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#64748B" />
            <Button Content="⏮️" Style="{StaticResource PaginationButtonStyle}" x:Name="BtnBegin" />
            <Button Content="◀️" Style="{StaticResource PaginationButtonStyle}" x:Name="BtnBackward" />
            <Button Content="▶️" Style="{StaticResource PaginationButtonStyle}" x:Name="BtnForward" />
            <Button Content="⏭️" Style="{StaticResource PaginationButtonStyle}" x:Name="BtnEnd" />
        </StackPanel>
    </Grid>
</Page>
