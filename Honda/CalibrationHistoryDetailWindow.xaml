<Window x:Class="CalibrationHistoryDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration History Detail" Height="850" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="SectionHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Margin" Value="0,15,0,0"/>
        </Style>
        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="CornerRadius" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1,0,1,1"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Summary Grid Styles -->
        <Style x:Key="SummaryHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,6"/>
            <Setter Property="BorderBrush" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="SummaryCellStyle" TargetType="DataGridCell">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border BorderBrush="#BBBBBB" BorderThickness="0,0,1,1" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SummaryFirstColumnCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource SummaryCellStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#F8FAFC"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Header -->
        <Border Background="#1E293B" CornerRadius="8" Padding="20,15" Margin="0,0,0,20">
            <TextBlock Text="Calibration History Detail" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Section 1: Basic Information -->
                <Border Style="{StaticResource SectionHeaderStyle}" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,10,0"/>
                        <TextBlock Text="Basic Information" Style="{StaticResource SectionHeaderTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <UniformGrid Columns="5">
                        <StackPanel>
                            <TextBlock Text="Control No" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtControlNo" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Category" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtCategory" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Type Name" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTypeName" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Found Cycle" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtCycle" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Calibration Date" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtCalDate" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Section 2: Technical Specifications -->
                <Border Style="{StaticResource SectionHeaderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,10,0"/>
                        <TextBlock Text="Technical Specifications" Style="{StaticResource SectionHeaderTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <UniformGrid Columns="4">
                        <StackPanel>
                            <TextBlock Text="Range/Size" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtRange" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="L.C" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtLC" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Colour" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtColor" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Location" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtLocation" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Temperature" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTemp" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Humidity" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtHum" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="TMU" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTMU" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Depth Error (mm)" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtDepthError" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <!-- Section 3: Measurements -->
                <Border Style="{StaticResource SectionHeaderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,10,0"/>
                        <TextBlock Text="Measurements" Style="{StaticResource SectionHeaderTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel x:Name="ObservationsPanel"/>
                </Border>

                <!-- Section 4: Results & Timing -->
                <Border Style="{StaticResource SectionHeaderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,10,0"/>
                        <TextBlock Text="Results &amp; Timing" Style="{StaticResource SectionHeaderTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Time In" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTimeIn" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Time Out" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTimeOut" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Total Time" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtTotalTime" Text="-" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Status" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtStatus" Text="-" Foreground="Black" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Remark" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="TxtRemark" Text="-" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Button Content="Close" Click="BtnClose_Click" HorizontalAlignment="Right" 
                        Margin="0,30,0,10" Width="120" Height="36" Background="#1E293B" Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
