<Window x:Class="HeightGauge600"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="Height Gauge 0-600mm" Height="820" Width="1030"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Segoe UI Variable, Arial">

    <!-- Global Styles for modern look -->
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Margin="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Row 0: Heading -->
                <RowDefinition Height="Auto" /> <!-- Row 1: Header Section -->
                <RowDefinition Height="Auto" /> <!-- Row 2: Environmental Conditions -->
                <RowDefinition Height="Auto" /> <!-- Row 3: Selected Calibration Masters -->
                <RowDefinition Height="Auto" /> <!-- Row 4: Spacer -->
                <RowDefinition Height="Auto" /> <!-- Row 5: Observations Panel -->
                <RowDefinition Height="Auto" /> <!-- Row 6: Bottom Utility Panel -->
            </Grid.RowDefinitions>

            <!-- Top Left Heading -->
            <TextBlock Grid.Row="0" Text="Height Gauge 0-600mm" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10" HorizontalAlignment="Left" />

            <!-- Header and Base Details -->
            <GroupBox Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="85"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Control No:" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextBox1" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Category:" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ComboBox1" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Location:" />
                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="ComboBox2" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="LC (mm):" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboBox5" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Calibration Date:" />
                    <DatePicker Grid.Row="2" Grid.Column="4" x:Name="TxtCalibrationDate" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2" Grid.Column="6" Text="Size:" />
                    <ComboBox Grid.Row="2" Grid.Column="7" x:Name="TextBox21" HorizontalAlignment="Stretch" />

                    <!-- Row 4 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Color:" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TextBoxColor" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Calibration master:" />
                    <Grid Grid.Row="4" Grid.Column="4">
                        <Button x:Name="BtnBrowseMaster" Content="..." Width="60" Height="26" HorizontalAlignment="Left" />
                    </Grid>

                </Grid>
            </GroupBox>

            <!-- Environmental Conditions -->
            <GroupBox Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="75" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="45" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Temperature:" />
                    <TextBox Grid.Column="1" x:Name="TextBox30" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="3" Text="Humidity:" />
                    <TextBox Grid.Column="4" x:Name="TextBox28" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="6" Text="TMU:" />
                    <TextBox Grid.Column="7" x:Name="TextBox29" HorizontalAlignment="Stretch" />
                </Grid>
            </GroupBox>

            <!-- Selected Calibration Masters (Dynamic Section) -->
            <GroupBox x:Name="MasterGroupBox" Grid.Row="3" Visibility="Collapsed" Margin="0,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsControlSelectedMasters">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="12,6" Margin="0,0,10,6" Background="#F8FAFC">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" />
                                        <TextBlock Text=" | " Foreground="#64748B" Margin="6,0" />
                                        <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- Observations Panel -->
            <GroupBox Grid.Row="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Column 1: 0 to 100mm -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="55"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="0 mm:" x:Name="Label0" />
                        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt0_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt0_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt0_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="20 mm:" x:Name="Label20" />
                        <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt20_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt20_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt20_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="50 mm:" x:Name="Label50" />
                        <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt50_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt50_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt50_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="100 mm:" x:Name="Label100" />
                        <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt100_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt100_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt100_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>
                    </Grid>

                    <!-- Column 2: 150 to 300mm -->
                    <Grid Grid.Column="1" Margin="5,0,5,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="150 mm:" x:Name="Label150" />
                        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt150_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt150_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt150_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="200 mm:" x:Name="Label200" />
                        <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt200_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt200_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt200_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="250 mm:" x:Name="Label250" />
                        <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt250_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt250_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt250_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="300 mm:" x:Name="Label300" />
                        <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt300_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt300_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt300_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>
                    </Grid>

                    <!-- Column 3: 350 to 500mm -->
                    <Grid Grid.Column="2" Margin="5,0,5,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="350 mm:" x:Name="Label350" />
                        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt350_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt350_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt350_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="400 mm:" x:Name="Label400" />
                        <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt400_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt400_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt400_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="450 mm:" x:Name="Label450" />
                        <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt450_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt450_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt450_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="500 mm:" x:Name="Label500" />
                        <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt500_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt500_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt500_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>
                    </Grid>

                    <!-- Column 4: 550 and 600mm -->
                    <Grid Grid.Column="3" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <RowDefinition Height="4" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="550 mm:" x:Name="Label550" />
                        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt550_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt550_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt550_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="600 mm:" x:Name="Label600" />
                        <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                            <TextBox x:Name="txt600_1" Margin="0,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt600_2" Margin="1,0,1,0" Padding="1" FontSize="11" />
                            <TextBox x:Name="txt600_3" Margin="1,0,0,0" Padding="1" FontSize="11" />
                        </UniformGrid>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- Bottom Tracking Details -->
            <GroupBox Grid.Row="6" Margin="0,6,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Time In:" />
                        <TextBox Grid.Column="1" x:Name="TextBox24" HorizontalAlignment="Stretch" />

                        <TextBlock Grid.Column="3" Text="Time Out:" />
                        <TextBox Grid.Column="4" x:Name="TextBox26" HorizontalAlignment="Stretch" />

                        <TextBlock Grid.Column="6" Text="Total Duration:" />
                        <TextBox Grid.Column="7" x:Name="TextBox25" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Status:" />
                        <ComboBox Grid.Column="1" x:Name="ComboBox4" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="OK" />
                            <ComboBoxItem Content="NG" />
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Remarks:" />
                        <TextBox Grid.Column="4" x:Name="TextBox19" HorizontalAlignment="Stretch" />
                        
                        <!-- Hidden Date for Logic Compatibility -->
                        <TextBox x:Name="TextBox27" Visibility="Collapsed" />
                    </Grid>

                    <Button Grid.Row="6" x:Name="Button2" Content="SAVE FINAL RECORD" Height="42" FontSize="15" FontWeight="Bold" Width="260" HorizontalAlignment="Center" />
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
