<Page x:Class="CategorySelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Honda"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Select Category"
      Background="#F1F5F9"
      UseLayoutRounding="True"
      TextOptions.TextFormattingMode="Display">

    <Page.Resources>
        <local:Base64ToImageConverter x:Key="Base64ToImageConverter" />
        <local:Base64ToVisibilityConverter x:Key="Base64ToVisibilityConverter" />
        <Style x:Key="HeaderSecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CategoryCardStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Width" Value="280" />
            <Setter Property="Height" Value="160" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="#3B82F6" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" x:Name="border">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Custom Image or Default Icon -->
                                <Grid Height="50" Margin="0,0,0,12">
                                    <!-- Default Icon (Only visible if no image) -->
                                    <Path x:Name="DefaultIcon" 
                                          Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,17L15,13H13V7H11V13H9L12,17Z" 
                                          Fill="#3B82F6" Width="50" Height="50" Stretch="Uniform" Opacity="0.9"
                                          Visibility="{Binding TypeImage, Converter={StaticResource Base64ToVisibilityConverter}, ConverterParameter=Inverse}" />
                                    
                                    <!-- Custom Image -->
                                    <Image x:Name="CustomImage"
                                           Source="{Binding TypeImage, Converter={StaticResource Base64ToImageConverter}}"
                                           Width="50" Height="50" Stretch="Uniform"
                                           Visibility="{Binding TypeImage, Converter={StaticResource Base64ToVisibilityConverter}}" />
                                </Grid>
                                
                                <TextBlock Text="{Binding TypeName}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0.7">
                                    <TextBlock Text="PrefixMode: " FontSize="11" />
                                    <TextBlock Text="{Binding PrefixMode}" FontSize="11" />
                                    <TextBlock Text="  Digits: " FontSize="11" />
                                    <TextBlock Text="{Binding SerialDigits}" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Breadcrumb & Back -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Database " FontSize="14" Foreground="#64748B" />
            <TextBlock Text=" > " FontSize="14" Foreground="#94A3B8" />
            <TextBlock x:Name="TxtCategoryBreadcrumb" Text="Gauges" FontSize="14" Foreground="#64748B" FontWeight="SemiBold" />
            
            <Button Content="← Back" Margin="40,0,0,0" Padding="12,4" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" x:Name="BtnBack" Click="BtnBack_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <TextBlock x:Name="TxtTitle" Grid.Row="1" Text="Select Gauge Type" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4" />
        <TextBlock x:Name="TxtSubtitle" Grid.Row="2" Text="Types are configured in Settings > Types" Foreground="#64748B" FontSize="13" Margin="0,0,0,32" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="CardsContainer">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource CategoryCardStyle}" Click="Card_Click" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
