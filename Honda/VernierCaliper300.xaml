<Window x:Class="VernierCaliper300"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Honda"
        mc:Ignorable="d"
        Title="vernier caliper 0-300mm" Height="820" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        FontFamily="Segoe UI, Segoe UI Variable, Arial">

    <!-- Global Styles for modern look -->
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2" />
                                </Border.Effect>
                                <ContentPresenter Margin="16" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Row 0: Heading -->
                <RowDefinition Height="Auto" /> <!-- Row 1: Header Section -->
                <RowDefinition Height="Auto" /> <!-- Row 2: Environmental Conditions -->
                <RowDefinition Height="Auto" /> <!-- Row 3: Selected Calibration Masters -->
                <RowDefinition Height="Auto" /> <!-- Row 4: error observation Banner -->
                <RowDefinition Height="Auto" /> <!-- Row 5: Observations Panel -->
                <RowDefinition Height="Auto" /> <!-- Row 6: Bottom Utility Panel -->
            </Grid.RowDefinitions>

            <!-- Top Left Heading -->
            <TextBlock Grid.Row="0" Text="vernier calliper 0-300" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10" HorizontalAlignment="Left" />

            <!-- Header and Base Details -->
            <GroupBox Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="85"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="130" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" MinWidth="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Row 0 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Control No:" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TextBox1" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Category:" />
                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ComboBox1" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Location:" />
                    <TextBox Grid.Row="0" Grid.Column="7" x:Name="ComboBox2" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <!-- Row 2 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="LC (mm):" />
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ComboBox5" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="Calibration Date:" />
                    <DatePicker Grid.Row="2" Grid.Column="4" x:Name="TxtCalibrationDate" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2" Grid.Column="6" Text="Size:" />
                    <ComboBox Grid.Row="2" Grid.Column="7" x:Name="TextBox21" HorizontalAlignment="Stretch" />

                    <!-- Row 4 -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Color:" />
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="TextBoxColor" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Calibration master:" />
                    <Grid Grid.Row="4" Grid.Column="4">
                        <Button x:Name="BtnBrowseMaster" Content="..." Width="60" Height="26" HorizontalAlignment="Left" Click="BtnBrowseMaster_Click" />
                    </Grid>

                </Grid>
            </GroupBox>

            <!-- Environmental Conditions -->
            <GroupBox Grid.Row="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="75" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="45" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" MinWidth="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Temperature:" />
                    <TextBox Grid.Column="1" x:Name="TextBox30" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="3" Text="Humidity:" />
                    <TextBox Grid.Column="4" x:Name="TextBox28" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="6" Text="TMU:" />
                    <TextBox Grid.Column="7" x:Name="TextBox29" HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="9" Text="Depth Error:" />
                    <TextBox Grid.Column="10" x:Name="TextBox20" HorizontalAlignment="Stretch" />
                </Grid>
            </GroupBox>

            <!-- Selected Calibration Masters (Dynamic Section) -->
            <GroupBox x:Name="MasterGroupBox" Grid.Row="3" Visibility="Collapsed" Margin="0,6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ItemsControlSelectedMasters">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Padding="12,6" Margin="0,0,10,6" Background="#F8FAFC">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Description}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" />
                                        <TextBlock Text=" | " Foreground="#64748B" Margin="6,0" />
                                        <TextBlock Text="{Binding MasterUncertainty, StringFormat=N9}" Foreground="#0F172A" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <!-- Row 4: error observation Banner (Removed) -->



            <GroupBox Grid.Row="5">
                <StackPanel>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Block 1: External -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock x:Name="Label29" Text="External Observation" FontWeight="Bold" FontSize="16" Margin="0,0,0,16" Foreground="Black"/>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 0mm and 150mm -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="0 mm:" x:Name="LabelExt0" />
                                <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtExt0_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt0_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt0_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="0" Grid.Column="3" Text="150 mm:" x:Name="LabelExt150" />
                                <UniformGrid Grid.Row="0" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtExt150_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt150_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt150_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <!-- 20mm and 200mm -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="20 mm:" x:Name="LabelExt20" />
                                <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtExt20_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt20_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt20_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="2" Grid.Column="3" Text="200 mm:" x:Name="LabelExt200" />
                                <UniformGrid Grid.Row="2" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtExt200_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt200_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt200_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <!-- 50mm and 250mm -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="50 mm:" x:Name="LabelExt50" />
                                <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtExt50_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt50_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt50_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="4" Grid.Column="3" Text="250 mm:" x:Name="LabelExt250" />
                                <UniformGrid Grid.Row="4" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtExt250_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt250_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt250_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <!-- 100mm and 300mm -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="100 mm:" x:Name="LabelExt100" />
                                <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtExt100_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt100_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt100_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="6" Grid.Column="3" Text="300 mm:" x:Name="LabelExt300" />
                                <UniformGrid Grid.Row="6" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtExt300_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt300_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtExt300_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>
                            </Grid>
                        </StackPanel>

                        <!-- Block 2: Internal -->
                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="Label38" Text="Internal Observation" FontWeight="Bold" FontSize="16" Margin="0,0,0,16" Foreground="Black"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="4" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto" MinWidth="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 0mm and 150mm -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="0 mm:" x:Name="LabelInt0" />
                                <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtInt0_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt0_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt0_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="0" Grid.Column="3" Text="150 mm:" x:Name="LabelInt150" />
                                <UniformGrid Grid.Row="0" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtInt150_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt150_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt150_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <!-- 20mm and 200mm -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="20 mm:" x:Name="LabelInt20" />
                                <UniformGrid Grid.Row="2" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtInt20_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt20_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt20_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="2" Grid.Column="3" Text="200 mm:" x:Name="LabelInt200" />
                                <UniformGrid Grid.Row="2" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtInt200_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt200_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt200_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <!-- 50mm and 250mm -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="50 mm:" x:Name="LabelInt50" />
                                <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtInt50_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt50_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt50_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="4" Grid.Column="3" Text="250 mm:" x:Name="LabelInt250" />
                                <UniformGrid Grid.Row="4" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtInt250_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt250_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt250_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <!-- 100mm and 300mm -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="100 mm:" x:Name="LabelInt100" />
                                <UniformGrid Grid.Row="6" Grid.Column="1" Columns="3">
                                    <TextBox x:Name="txtInt100_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt100_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt100_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>

                                <TextBlock Grid.Row="6" Grid.Column="3" Text="300 mm:" x:Name="LabelInt300" />
                                <UniformGrid Grid.Row="6" Grid.Column="4" Columns="3">
                                    <TextBox x:Name="txtInt300_1" Margin="0,0,2,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt300_2" Margin="1,0,1,0" Padding="2" FontSize="12" />
                                    <TextBox x:Name="txtInt300_3" Margin="2,0,0,0" Padding="2" FontSize="12" />
                                </UniformGrid>
                            </Grid>
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Bottom Tracking Details -->
            <GroupBox Grid.Row="6" Margin="0,6,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Time In:" />
                        <TextBox Grid.Column="1" x:Name="TextBox24" HorizontalAlignment="Stretch" />

                        <TextBlock Grid.Column="3" Text="Time Out:" />
                        <TextBox Grid.Column="4" x:Name="TextBox26" HorizontalAlignment="Stretch" />

                        <TextBlock Grid.Column="6" Text="Total Duration:" />
                        <TextBox Grid.Column="7" x:Name="TextBox25" HorizontalAlignment="Stretch" IsReadOnly="True" Background="#F1F5F9" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="Auto" MinWidth="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Status:" />
                        <ComboBox Grid.Column="1" x:Name="ComboBox4" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="OK" />
                            <ComboBoxItem Content="NG" />
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="Remarks:" />
                        <TextBox Grid.Column="4" x:Name="TextBox19" HorizontalAlignment="Stretch" />
                        
                        <!-- Hidden Date for Logic Compatibility -->
                        <TextBox x:Name="TextBox27" Visibility="Collapsed" />
                    </Grid>

                    <Button Grid.Row="6" x:Name="Button2" Content="SAVE FINAL RECORD" Height="42" FontSize="15" FontWeight="Bold" Width="260" HorizontalAlignment="Center" />
                </Grid>

            </GroupBox>
        </Grid>
    </ScrollViewer>

</Window>
